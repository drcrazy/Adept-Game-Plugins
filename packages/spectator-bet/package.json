{
  "name": "@adept-plugins/spectator-bet",
  "version": "1.0.0",
  "description": "Spectator bet segment — lobby → spectator_bet → round:1",
  "type": "module",
  "main": "./dist/server.js",
  "exports": {
    ".": "./dist/server.js",
    "./client": "./dist/client.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "@adept/plugin-sdk": "^1.0.0",
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@adept/plugin-sdk": "*",
    "@types/react": "^18.3.0",
    "typescript": "^5.7.2"
  },
  "adept": {
    "pluginId": "spectator-bet",
    "apiVersion": 1,
    "capabilities": {
      "segments": [
        {
          "id": "spectator_bet",
          "slot": "after:lobby",
          "next": "round:1"
        }
      ],
      "cardKinds": []
    }
  }
}
